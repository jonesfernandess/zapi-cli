{
  "name": "zapi-cli",
  "version": "1.0.0",
  "description": "CLI tool for Z-API WhatsApp API",
  "main": "dist/cli.js",
  "bin": {
    "zapi": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.17.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "keywords": ["z-api", "zapi", "whatsapp", "cli"],
  "license": "MIT"
}
